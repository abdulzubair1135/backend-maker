# Server Config
PORT=8000
NODE_ENV=production

# Database Config (MySQL)
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=wss_db
DB_PORT=3306

# Security Configuration
JWT_SECRET=super_secret_key_at_least_64_characters_long_for_security
JWT_REFRESH_SECRET=another_super_secret_key_at_least_64_characters_long_for_security
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=7d

# Rate Limiter
RATE_LIMIT_WINDOW_MS=900000 # 15 minutes
RATE_LIMIT_MAX=100
